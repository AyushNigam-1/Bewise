{
  "consumer": {
    "name": "BookistFrontend"
  },
  "interactions": [
    {
      "description": "a request to get all bookmarked books",
      "providerStates": [
        {
          "name": "a request to get all bookmarked books"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/bookmarks/books"
      },
      "response": {
        "body": {
          "books": [
            {
              "author": "James Clear",
              "category": [
                "productivity"
              ],
              "description": "A book about habits",
              "id": 1,
              "thumbnail": "url.png",
              "title": "Atomic Habits"
            }
          ],
          "categories": [
            {
              "description": "Explore insights from this category.",
              "icon": "📌",
              "name": "productivity"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.books": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.books[*].author": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.books[*].category": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.books[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.books[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.books[*].thumbnail": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.books[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.categories": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.categories[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.categories[*].icon": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.categories[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to get all bookmarked insights",
      "providerStates": [
        {
          "name": "a request to get all bookmarked insights"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/bookmarks/insights"
      },
      "response": {
        "body": {
          "categories": [
            {
              "description": "Python",
              "icon": "🐍",
              "name": "python"
            }
          ],
          "insights": [
            {
              "insight_id": 42,
              "title": "Keep functions small"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.categories": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.categories[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.categories[*].icon": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.categories[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.insights": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.insights[*].insight_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.insights[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to toggle a book bookmark",
      "request": {
        "method": "POST",
        "path": "/bookmark/book/1"
      },
      "response": {
        "body": {
          "favourite_books": [
            1
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.favourite_books": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to toggle an insight bookmark",
      "request": {
        "method": "POST",
        "path": "/bookmark/insight/42"
      },
      "response": {
        "body": {
          "bookmarked": true,
          "favourite_insights": [
            42
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.bookmarked": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.favourite_insights": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "BookistBackend"
  }
}